@Component
public class BankCoreClient {
    private final WebClient webClient;

    public BankCoreClient(@Value("${external.bank-core.base-url}") String baseUrl) {
        this.webClient = WebClient.builder()
                                  .baseUrl(baseUrl)    // Configura base URL do serviço Banco
                                  .build();
    }

    public BankUserContext validateToken(String token) {
        // Chama GET /auth/me no serviço Banco, passando o token
        return webClient.get()
            .uri("/auth/me")
            .header("Authorization", token)
            .retrieve()
            .bodyToMono(BankUserContext.class)
            .block();
    }
}
